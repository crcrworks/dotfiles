# skhd が Login Item / BTM 経由で起動すると PATH に mise の shims が入らない。
# このままだと `yabai` が見つからずホットキーが無反応になるためフルパスで指定する。
.shell "/bin/bash"

# ウィンドウのフォーカス移動
alt - h : /opt/homebrew/bin/yabai -m window --focus west
alt - j : /opt/homebrew/bin/yabai -m window --focus south
alt - k : /opt/homebrew/bin/yabai -m window --focus north
alt - l : /opt/homebrew/bin/yabai -m window --focus east

# ウィンドウの入れ替え
shift + alt - h : /opt/homebrew/bin/yabai -m window --swap west
shift + alt - j : /opt/homebrew/bin/yabai -m window --swap south
shift + alt - k : /opt/homebrew/bin/yabai -m window --swap north
shift + alt - l : /opt/homebrew/bin/yabai -m window --swap east

# ウィンドウの移動（warp）
ctrl + shift + alt - h : /opt/homebrew/bin/yabai -m window west --insert south; /opt/homebrew/bin/yabai -m window --warp west
ctrl + shift + alt - j : /opt/homebrew/bin/yabai -m window south --insert east; /opt/homebrew/bin/yabai -m window --warp south
ctrl + shift + alt - k : /opt/homebrew/bin/yabai -m window north --insert west; /opt/homebrew/bin/yabai -m window --warp north
ctrl + shift + alt - l : /opt/homebrew/bin/yabai -m window east --insert north; /opt/homebrew/bin/yabai -m window --warp east

# スペースへフォーカス移動（最初のウィンドウを選択）
alt - 1 : /opt/homebrew/bin/yabai -m space --focus 1
alt - 2 : /opt/homebrew/bin/yabai -m space --focus 2
alt - 3 : /opt/homebrew/bin/yabai -m space --focus 3
alt - 4 : /opt/homebrew/bin/yabai -m space --focus 4


alt - a : /opt/homebrew/bin/yabai -m space --focus 1
alt - s : /opt/homebrew/bin/yabai -m space --focus 2
alt - d : /opt/homebrew/bin/yabai -m space --focus 3

alt - q : /opt/homebrew/bin/yabai -m space --focus 4
alt - w : /opt/homebrew/bin/yabai -m space --focus 5
alt - e : /opt/homebrew/bin/yabai -m space --focus 6

alt - z : /opt/homebrew/bin/yabai -m space --focus 7
alt - x : /opt/homebrew/bin/yabai -m space --focus 8
alt - c : /opt/homebrew/bin/yabai -m space --focus 9

# ウィンドウを別スペースに移動
shift + alt - 1 : /opt/homebrew/bin/yabai -m window --space 1
shift + alt - 2 : /opt/homebrew/bin/yabai -m window --space 2
shift + alt - 3 : /opt/homebrew/bin/yabai -m window --space 3
shift + alt - 4 : /opt/homebrew/bin/yabai -m window --space 4

shift + alt - q : /opt/homebrew/bin/yabai -m window --space 4
shift + alt - w : /opt/homebrew/bin/yabai -m window --space 5
shift + alt - e : /opt/homebrew/bin/yabai -m window --space 6

shift + alt - a : /opt/homebrew/bin/yabai -m window --space 1
shift + alt - s : /opt/homebrew/bin/yabai -m window --space 2
shift + alt - d : /opt/homebrew/bin/yabai -m window --space 3

shift + alt - z : /opt/homebrew/bin/yabai -m window --space 7
shift + alt - x : /opt/homebrew/bin/yabai -m window --space 8
shift + alt - c : /opt/homebrew/bin/yabai -m window --space 9

# スペースを左右に移動
alt - tab : /opt/homebrew/bin/yabai -m space --focus next
shift + alt - tab : /opt/homebrew/bin/yabai -m space --focus prev

# ウィンドウ操作
alt + ctrl - return : /opt/homebrew/bin/yabai -m window --toggle zoom-fullscreen
shift + ctrl - f : /opt/homebrew/bin/yabai -m window --toggle float
shift + ctrl - s : /opt/homebrew/bin/yabai -m window --toggle sticky
shift + ctrl - p : /opt/homebrew/bin/yabai -m window --toggle sticky --toggle pip
shift + ctrl - e : /opt/homebrew/bin/yabai -m window --toggle expose

# ウィンドウをstack（重ねる）
shift + ctrl - h : /opt/homebrew/bin/yabai -m window west --stack $(/opt/homebrew/bin/yabai -m query --windows --window | jq -r '.id')
shift + ctrl - j : /opt/homebrew/bin/yabai -m window south --stack $(/opt/homebrew/bin/yabai -m query --windows --window | jq -r '.id')
shift + ctrl - k : /opt/homebrew/bin/yabai -m window north --stack $(/opt/homebrew/bin/yabai -m query --windows --window | jq -r '.id')
shift + ctrl - l : /opt/homebrew/bin/yabai -m window east --stack $(/opt/homebrew/bin/yabai -m query --windows --window | jq -r '.id')

# stack内のウィンドウを切り替え
alt - n : /opt/homebrew/bin/yabai -m window --focus stack.next || /opt/homebrew/bin/yabai -m window --focus stack.first
alt - p : /opt/homebrew/bin/yabai -m window --focus stack.prev || /opt/homebrew/bin/yabai -m window --focus stack.last

# stackを解除（unstack）
# 方法1: 別ウィンドウがある場合はwarpで解除
shift + ctrl - u : /opt/homebrew/bin/yabai -m window --toggle float && /opt/homebrew/bin/yabai -m window --toggle float

# ウィンドウサイズ調整
ctrl + lalt - h    : /opt/homebrew/bin/yabai -m window --resize right:-100:0 || /opt/homebrew/bin/yabai -m window --resize left:-100:0
ctrl + lalt - j    : /opt/homebrew/bin/yabai -m window --resize bottom:0:100 || /opt/homebrew/bin/yabai -m window --resize top:0:100
ctrl + lalt - k    : /opt/homebrew/bin/yabai -m window --resize bottom:0:-100 || /opt/homebrew/bin/yabai -m window --resize top:0:-100
ctrl + lalt - l : /opt/homebrew/bin/yabai -m window --resize right:100:0 || /opt/homebrew/bin/yabai -m window --resize left:100:0

lalt + shift - return : /opt/homebrew/bin/yabai -m window --toggle zoom-parent
