[
  {
    "context": "Editor && vim_mode == normal && VimControl && !menu",
    "bindings": {
      ";": "command_palette::Toggle",
      "space enter": "editor::Cancel",
      "space w": "workspace::Save",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "tab": "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePreviousItem",
      "\\": "pane::SplitDown",
      "|": "pane::SplitRight",
      "space c": "pane::CloseActiveItem",
      "space b": "tab_switcher::Toggle",
      "space /": "editor::ToggleComments",
      "space p s": "zed::Extensions",
      "space p m": "zed::OpenSettings",
      "space t r": "theme_selector::Toggle",
      "space e": "workspace::ToggleLeftDock",
      "space o": "project_panel::ToggleFocus",
      "space h": "pane::SplitDown",
      "space v": "pane::SplitRight",
      "space f f": "file_finder::Toggle",
      "space f shift-f": "file_finder::Toggle",
      "space f w": "pane::DeploySearch",
      "space f shift-w": "pane::DeploySearch",
      "space f b": "tab_switcher::Toggle",
      "space f c": ["buffer_search::Deploy", { "selection_search_enabled": true }],
      "space f shift-c": "command_palette::Toggle",
      "space f g": "file_finder::Toggle",
      "space f l": "buffer_search::Deploy",
      "space f o": "file_finder::Toggle",
      "space f shift-o": "file_finder::Toggle",
      "space f p": ["projects::OpenRecent", { "create_new_window": false }],
      "space f s": "tab_switcher::Toggle",
      "space f k": "zed::OpenKeymap",
      "space f h": "zed::OpenSettings",
      "space l s": "project_symbols::Toggle",
      "space l f": "editor::Format",
      "space l shift-d": "diagnostics::Deploy",
      "space l a": "editor::ToggleCodeActions",
      "space g b": "branches::OpenRecent",
      "space g c": "git::ReviewDiff",
      "space g shift-c": "git::Blame",
      "space g t": "git_panel::ToggleFocus",
      "space g d": "git::Diff",
      "g l": "editor::Hover"
    }
  },
  {
    "context": "Editor && vim_mode == visual && VimControl && !menu",
    "bindings": {
      "space /": "editor::ToggleComments",
      "tab": "editor::Tab",
      "shift-tab": "editor::Backtab"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-b": ["editor::MoveToBeginningOfLine", { "stop_at_soft_wraps": true, "stop_at_indent": true }],
      "ctrl-e": ["editor::MoveToEndOfLine", { "stop_at_soft_wraps": false }],
      "ctrl-h": "editor::MoveLeft",
      "ctrl-l": "editor::MoveRight",
      "ctrl-j": "editor::MoveDown",
      "ctrl-k": "editor::MoveUp"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-x": ["terminal::SendKeystroke", "escape"]
    }
 },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "space e": "workspace::ToggleLeftDock",
      "space shift-e": "workspace::ToggleLeftDock"
    }
  }
]
